; OCaml folds
[
  (let_binding)
  (let_expression)
  (fun_expression)
  (function_expression)
  (match_expression)

  (value_definition)
  (type_definition)
  (module_definition)
  (module_binding)
  (class_definition)
  (class_binding)

  (structure)
  (signature)
  (object_expression)
  (class_body_type)

  (if_expression)
  (for_expression)
  (while_expression)
  (try_expression)

  (record_expression)
  (record_declaration)
  (list_expression)
  (array_expression)
] @fold

; OCaml interface folds
[
  (value_specification)
  (method_specification)
  (class_type_definition)
  (class_type_binding)
  (inheritance_specification)
  (instance_variable_specification)
] @fold
